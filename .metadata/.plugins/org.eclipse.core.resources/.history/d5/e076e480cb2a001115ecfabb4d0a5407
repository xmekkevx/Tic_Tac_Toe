void clearTerminal(void)
{
    printf("\033[2J\033[H");
}

void lcd_show_1line(uint8_t line, char* text)
{
    if (line > 1) return;

    lcd_cur_pos(0, line);
    lcd_put_str("        ");

    lcd_cur_pos(0, line);
    lcd_put_str(text);
}

void lcd_show_2lines(char* line1, char* line2)
{
    lcd_clr();

    lcd_cur_pos(0, 0);
    lcd_put_str(line1);

    lcd_cur_pos(0, 1);
    lcd_put_str(line2);
}

char uart_getchar(void)
{
    char c;
    HAL_UART_Receive(&huart2, (uint8_t*)&c, 1, HAL_MAX_DELAY);
    return c;
}

void lcd_show_player(char player)
{
    char line1[9];
    char line2[9];

    snprintf(line1, sizeof(line1), "Start:%c", player);
    snprintf(line2, sizeof(line2), "Turn: %c", player);

    lcd_show_2lines(line1, line2);
}

void greet(void)
{
    lcd_show_2lines("Welcome ", "to...  ");
    HAL_Delay(2000);

    lcd_show_2lines(" TicTac ", "  Toe! ");
    HAL_Delay(2000);

    lcd_clr();
}

int askStartGame(void)
{
    char choice;
    char line2[16] = "(j/n): ";

    lcd_clr();
    lcd_cur_pos(0, 0);
    lcd_put_str("Start?");

    lcd_cur_pos(0, 1);
    lcd_put_str(line2);

    choice = uart_getchar();

    lcd_cur_pos(strlen(line2), 1);
    lcd_putc(choice);

    HAL_Delay(500);

    if (choice == 'j' || choice == 'J')
        return 1;
    else
        return 0;
}

int askReplay(void)
{
    char choice;
    char line1[] = "Again?";
    char line2[] = "(j/n): ";

    lcd_show_2lines(line1, line2);

    choice = uart_getchar();

    lcd_cur_pos(strlen(line2), 1);
    lcd_putc(choice);

    printf("%c\r\n", choice);

    HAL_Delay(1000);

    if (choice == 'j' || choice == 'J')
        return 1;

    return 0;
}

void startGame(Game *game)
{
    int input;
    int move;

    lcd_show_2lines("Game", "starts!");
    HAL_Delay(2000);

    initGame(game);

    if (rand() % 2 == 0)
        game->currentPlayer = 'X';
    else
        game->currentPlayer = 'O';

    printf("\n============================\r\n");
    printf("Neues Spiel startet\r\n");
    printf("Startspieler: %c\r\n", game->currentPlayer);
    printf("============================\r\n");

    lcd_show_player(game->currentPlayer);
    HAL_Delay(1500);

    while (1)
    {
        printBoard(game);

        if (game->currentPlayer == 'X')
        {
            printf("\r\nDein Zug!\r\n");
            printf("Waehle Feld 1-9, Taste 13 = Korrektur, Taste 16 = Enter\r\n");

            input = keyboard_get_confirmed_move_1_to_9();

            printf("Zug bestaetigt: Feld %d\r\n", input);

            if (!playerMove(game, input))
            {
                printf("Feld %d ist bereits belegt!\r\n", input);
                lcd_show_2lines("Field", "Taken! ");
                HAL_Delay(1200);
                continue;
            }

            lcd_show_2lines("You chose", "Accepted");
            HAL_Delay(800);
        }
        else
        {
            printf("\r\nKI denkt...\r\n");
            lcd_show_2lines("AI", "thinks...");
            HAL_Delay(2000);

            move = aiMove(game);

            printf("KI waehlt Feld %d\r\n", move);

            char aiMsg[9];
            snprintf(aiMsg, sizeof(aiMsg), "Fld:%d", move);

            lcd_show_2lines("AI move:", aiMsg);
            HAL_Delay(1800);

            playerMove(game, move);
        }

        if (checkWin(game, game->currentPlayer))
        {
            printBoard(game);

            if (game->currentPlayer == 'X')
            {
                printf("\r\nDu hast gewonnen!\r\n");
                lcd_show_2lines("You", "win!");
                HAL_Delay(2000);
            }
            else
            {
                printf("\r\nDie KI gewinnt!\r\n");
                lcd_show_2lines("AI", "wins!");
                HAL_Delay(2000);
            }

            break;
        }

        if (isDraw(game))
        {
            printBoard(game);

            printf("\r\nUnentschieden!\r\n");
            lcd_show_2lines("Draw!", "No winner");
            HAL_Delay(2000);

            break;
        }

        switchPlayer(game);

        if (game->currentPlayer == 'X')
        {
            printf("\r\nJetzt bist du wieder dran.\r\n");
            lcd_show_player(game->currentPlayer);
            HAL_Delay(1000);
        }
        else
        {
            printf("\r\nJetzt ist die KI dran.\r\n");
            lcd_show_player(game->currentPlayer);
            HAL_Delay(1000);
        }
    }
}

