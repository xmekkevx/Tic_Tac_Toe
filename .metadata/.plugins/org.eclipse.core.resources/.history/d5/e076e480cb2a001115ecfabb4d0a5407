	          lcd_show_2lines("See you", "later!");
	          HAL_Delay(2000);

	          clearTerminal();
	          lcd_clr();
	          break;
	      }
	      else
	      {
	          clearTerminal();
	          lcd_clr();
	          printHelp();
	      }
	    }

  /* USER CODE END 3 */
}

