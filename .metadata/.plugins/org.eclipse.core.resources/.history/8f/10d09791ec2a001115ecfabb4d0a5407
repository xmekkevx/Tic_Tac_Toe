int askStartGame(void)
{
    return ui_ask_yes_no_question(
        "Moechtest du das Spiel starten?",
        "Start?",
        "Y/N ?",
        7,
        1
    );
}

int askReplay(void)
{
    return ui_ask_yes_no_question(
        "Moechtest du noch einmal spielen?",
        "Again?",
        "Y/N ?",
        7,
        1
    );
}

void startGame(Game *game)
{
    int input;
    int move;

    lcd_show_2lines("Game", "starts!");
    HAL_Delay(2000);

    initGame(game);

    if (rand() % 2 == 0)
        game->currentPlayer = 'X';
    else
        game->currentPlayer = 'O';

    ui_show_game_start(game->currentPlayer);
    ui_show_player_turn(game->currentPlayer);
    HAL_Delay(1500);

    while (1)
    {
    	ui_show_game_screen(game);

        if (game->currentPlayer == 'X')
        {
        	ui_show_player_prompt();
        	input = input_get_confirmed_move_1_to_9();

            if (!playerMove(game, input))
            {
            	ui_show_field_taken(input);
            	HAL_Delay(1200);
                continue;
            }

            ui_show_player_chosen();
            HAL_Delay(800);
        }
        else
        {
        	ui_show_ai_thinking();
        	HAL_Delay(2000);

            move = aiMove(game);

            ui_show_ai_move(move);
            HAL_Delay(1800);

            playerMove(game, move);
        }

        if (checkWin(game, game->currentPlayer))
        {
            printBoard(game);

            if (game->currentPlayer == 'X')
            {
            	ui_show_player_win();
            	HAL_Delay(2000);
            }
            else
            {
            	ui_show_ai_win();
            	HAL_Delay(2000);
            }

            break;
        }

        if (isDraw(game))
        {
            printBoard(game);

            ui_show_draw();
            HAL_Delay(2000);

            break;
        }

        switchPlayer(game);

        ui_show_player_turn(game->currentPlayer);
        HAL_Delay(1000);
    }
}


