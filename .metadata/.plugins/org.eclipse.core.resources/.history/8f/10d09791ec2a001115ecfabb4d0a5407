  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
	  startGame(&game);

	  if (!askReplay())
	  {
	      ui_show_program_end();
	      HAL_Delay(2000);

	      lcd_show_2lines("See you", "later!");
	      printf("Bis bald!\r\n");

	      HAL_Delay(2000);

	      ui_clear_terminal();
	      lcd_clr();
	      break;
	  }
	  else
	  {
	      ui_clear_terminal();
	      lcd_clr();
	      ui_print_help();
	  }
	}

  /* USER CODE END 3 */
}

