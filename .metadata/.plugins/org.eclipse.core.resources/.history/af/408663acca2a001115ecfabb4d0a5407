static void lcd_format_line(char *dst, const char *src)
{
    size_t i;

    for (i = 0; i < LCD_WIDTH; i++)
    {
        if (src[i] != '\0')
            dst[i] = src[i];
        else
            dst[i] = ' ';
    }
    dst[LCD_WIDTH] = '\0';
}

static void lcd_show_2lines_sync(const char *line1, const char *line2)
{
    char l1[LCD_WIDTH + 1];
    char l2[LCD_WIDTH + 1];

    lcd_format_line(l1, line1);
    lcd_format_line(l2, line2);

    lcd_clr();
    lcd_cur_pos(0, 0);
    lcd_put_str(l1);
    lcd_cur_pos(0, 1);
    lcd_put_str(l2);

    printf("[LCD] %s | %s\r\n", l1, l2);
}

static void lcd_show_1line_sync(uint8_t line, const char *text)
{
    char buf[LCD_WIDTH + 1];

    if (line > 1) return;

    lcd_format_line(buf, text);
    lcd_cur_pos(0, line);
    lcd_put_str("        ");
    lcd_cur_pos(0, line);
    lcd_put_str(buf);

    printf("[LCD] line %d: %s\r\n", line, buf);
}

