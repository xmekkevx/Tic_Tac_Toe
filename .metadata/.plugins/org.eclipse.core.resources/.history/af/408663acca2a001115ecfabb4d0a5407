void startGame(Game *game)
{
    int input;
    int move;
    char aiMsg[9];

    lcd_show_2lines_sync("Game", "starts!");
    HAL_Delay(1500);

    initGame(game);

    if (rand() % 2 == 0)
        game->currentPlayer = 'X';
    else
        game->currentPlayer = 'O';

    printf("\r\n============================\r\n");
    printf("Neues Spiel startet\r\n");
    printf("Startspieler: %c\r\n", game->currentPlayer);
    printf("============================\r\n");

    show_current_player(game->currentPlayer);
    HAL_Delay(1200);

    while (1)
    {
        printBoard(game);

        if (game->currentPlayer == 'X')
        {
            printf("\r\nDein Zug!\r\n");
            printf("Waehle Feld 1-9, Korrektur mit 13/Backspace/c, Hilfe mit 15/h, bestaetige mit 16/Enter\r\n");

            input = get_confirmed_move_dual();

            printf("Zug bestaetigt: Feld %d\r\n", input);

            if (!playerMove(game, input))
            {
                printf("Feld %d ist bereits belegt!\r\n", input);
                lcd_show_2lines_sync("Field", "Taken!");
                HAL_Delay(1200);
                continue;
            }

            snprintf(aiMsg, sizeof(aiMsg), "Fld:%d", input);
            lcd_show_2lines_sync("Chosen:", aiMsg);
            HAL_Delay(900);
        }
        else
        {
            printf("\r\nKI denkt...\r\n");
            lcd_show_2lines_sync("AI", "thinks");
            HAL_Delay(1800);

            move = aiMove(game);

            printf("KI waehlt Feld %d\r\n", move);

            snprintf(aiMsg, sizeof(aiMsg), "Fld:%d", move);
            lcd_show_2lines_sync("AI move", aiMsg);
            HAL_Delay(1500);

            playerMove(game, move);
        }

        if (checkWin(game, game->currentPlayer))
        {
            printBoard(game);

            if (game->currentPlayer == 'X')
            {
                printf("\r\nDu hast gewonnen!\r\n");
                lcd_show_2lines_sync("You", "win!");
                HAL_Delay(2000);
            }
            else
            {
                printf("\r\nDie KI gewinnt!\r\n");
                lcd_show_2lines_sync("AI", "wins!");
                HAL_Delay(2000);
            }

            break;
        }

        if (isDraw(game))
        {
            printBoard(game);

            printf("\r\nUnentschieden!\r\n");
            lcd_show_2lines_sync("Draw!", "No win");
            HAL_Delay(2000);

            break;
        }

        switchPlayer(game);

        if (game->currentPlayer == 'X')
        {
            printf("\r\nJetzt bist du wieder dran.\r\n");
            show_current_player(game->currentPlayer);
            HAL_Delay(900);
        }
        else
        {
            printf("\r\nJetzt ist die KI dran.\r\n");
            show_current_player(game->currentPlayer);
            HAL_Delay(900);
        }
    }
}
