static void draw_move_selection(uint8_t selected)
{
    char line2[9];

    if (selected == 0)
        snprintf(line2, sizeof(line2), "Sel:-OK");
    else
        snprintf(line2, sizeof(line2), "Sel:%d OK", selected);

    lcd_show_2lines_sync("Ur turn:", line2);
}

static uint8_t get_confirmed_move_dual(void)
{
    uint8_t selected = 0;
    uint8_t spi_key;
    char uart_char;

    draw_move_selection(selected);
    printf("Bitte waehlen: 1-9 = Feld, 13/Backspace/c = Korrektur, 16/Enter = bestaetigen, 15/h/? = Hilfe\r\n");

    while (1)
    {
        spi_key = keyboard_get_key_nonblocking();
        if (spi_key != 0)
        {
            printf("SPI-Taste gedrueckt: %d\r\n", spi_key);

            if (spi_key >= 1 && spi_key <= 9)
            {
                selected = spi_key;
                draw_move_selection(selected);
                printf("Aktuelle Auswahl: %d\r\n", selected);
            }
            else if (spi_key == 13)
            {
                selected = 0;
                draw_move_selection(selected);
                printf("Korrektur: Auswahl geloescht\r\n");
            }
            else if (spi_key == 15)
            {
                show_help_everywhere();
                draw_move_selection(selected);
                printf("Hilfe beendet. Auswahl bleibt: %s\r\n", (selected == 0) ? "keine" : "vorhanden");
            }
            else if (spi_key == 16)
            {
                if (selected >= 1 && selected <= 9)
                {
                    printf("Eingabe bestaetigt ueber SPI: %d\r\n", selected);
                    lcd_show_2lines_sync("Chosen:", (selected == 0) ? "-" : "OK");
                    HAL_Delay(600);
                    return selected;
                }
                else
                {
                    printf("Keine gueltige Auswahl zum Bestaetigen vorhanden\r\n");
                    lcd_show_2lines_sync("No sel!", "Choose");
                    HAL_Delay(700);
                    draw_move_selection(selected);
                }
            }
            else
            {
                printf("SPI-Taste %d wird ignoriert\r\n", spi_key);
            }
        }

        if (uart_getchar_nonblocking(&uart_char))
        {
            printf("UART-Eingabe: %c\r\n", uart_char);

            if (uart_char >= '1' && uart_char <= '9')
            {
                selected = (uint8_t)(uart_char - '0');
                draw_move_selection(selected);
                printf("Aktuelle Auswahl: %d\r\n", selected);
            }
            else if (uart_char == 8 || uart_char == 127 || uart_char == 'c' || uart_char == 'C')
            {
                selected = 0;
                draw_move_selection(selected);
                printf("Korrektur: Auswahl geloescht\r\n");
            }
            else if (uart_char == '\r' || uart_char == '\n')
            {
                if (selected >= 1 && selected <= 9)
                {
                    printf("Eingabe bestaetigt ueber UART: %d\r\n", selected);
                    lcd_show_2lines_sync("Chosen:", "OK");
                    HAL_Delay(600);
                    return selected;
                }
                else
                {
                    printf("Keine gueltige Auswahl zum Bestaetigen vorhanden\r\n");
                    lcd_show_2lines_sync("No sel!", "Choose");
                    HAL_Delay(700);
                    draw_move_selection(selected);
                }
            }
            else if (uart_char == 'h' || uart_char == 'H' || uart_char == '?')
            {
                show_help_everywhere();
                draw_move_selection(selected);
                printf("Hilfe beendet. Auswahl bleibt: %s\r\n", (selected == 0) ? "keine" : "vorhanden");
            }
            else
            {
                printf("UART-Zeichen '%c' wird ignoriert\r\n", uart_char);
            }
        }

        HAL_Delay(1);
    }
}

static int ask_yes_no_dual(const char *line1, const char *line2)
{
    uint8_t spi_key;
    char uart_char;

    lcd_show_2lines_sync(line1, line2);
    printf("Antwort moeglich mit UART: y/n oder mit SPI: 11=Yes, 12=No, 15=Help\r\n");

    while (1)
    {
        spi_key = keyboard_get_key_nonblocking();
        if (spi_key != 0)
        {
            printf("SPI-Taste gedrueckt: %d\r\n", spi_key);

            if (spi_key == 11)
            {
                lcd_show_2lines_sync(line1, "Yes");
                printf("Antwort: Yes (SPI 11)\r\n");
                HAL_Delay(500);
                return 1;
            }
            else if (spi_key == 12)
            {
                lcd_show_2lines_sync(line1, "No");
                printf("Antwort: No (SPI 12)\r\n");
                HAL_Delay(500);
                return 0;
            }
            else if (spi_key == 15)
            {
                show_help_everywhere();
                lcd_show_2lines_sync(line1, line2);
                printf("Zurueck zur Ja/Nein-Abfrage\r\n");
            }
            else
            {
                printf("SPI-Taste %d ist hier ungueltig\r\n", spi_key);
            }
        }

        if (uart_getchar_nonblocking(&uart_char))
        {
            printf("UART-Eingabe: %c\r\n", uart_char);

            if (uart_char == 'y' || uart_char == 'Y' || uart_char == 'j' || uart_char == 'J')
            {
                lcd_show_2lines_sync(line1, "Yes");
                printf("Antwort: Yes (UART)\r\n");
                HAL_Delay(500);
                return 1;
            }
            else if (uart_char == 'n' || uart_char == 'N')
            {
                lcd_show_2lines_sync(line1, "No");
                printf("Antwort: No (UART)\r\n");
                HAL_Delay(500);
                return 0;
            }
            else if (uart_char == 'h' || uart_char == 'H' || uart_char == '?')
            {
                show_help_everywhere();
                lcd_show_2lines_sync(line1, line2);
                printf("Zurueck zur Ja/Nein-Abfrage\r\n");
            }
            else
            {
                printf("UART-Zeichen '%c' ist hier ungueltig\r\n", uart_char);
            }
        }

        HAL_Delay(1);
    }
}

